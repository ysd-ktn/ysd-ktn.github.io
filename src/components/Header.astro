---
// Header — フローティングピル
// 通常時: 200×44px、ロゴ + + トグルだけ表示
// hover時: 横展開してナビが可視化
//
// nav 項目はモックの順序を維持。WORKS は現状なし、WRITING を 02 として配置。
// 言語切替 (EN / JP) は Phase 6 準備で削除済み (DESIGN_SPEC で未決のため、
// JP/EN コンテンツが揃うまでは UI 自体を出さない方針)。
//
// version はあとで package.json から読みたくなるかもしれないが、
// いったんモック通り `v3.0.0` を直書き。
const navItems = [
  { num: '00', label: 'INDEX', href: '#index' },
  { num: '01', label: 'ABOUT', href: '#about' },
  { num: '02', label: 'WRITING', href: '#writing' },
  { num: '03', label: 'CONTACT', href: '#contact' },
];

const logoText = 'YSD-KTN / v3.0.0';
---

<header>
  <span class="logo">{logoText}</span>
  <nav>
    {
      navItems.map((item) => (
        <a href={item.href}>
          <span class="num">{item.num}</span> {item.label}
        </a>
      ))
    }
  </nav>
  <span class="toggle" aria-hidden="true">+</span>
</header>

<!-- モバイル専用ナビバー (≤720px で表示、デスクトップでは display:none) -->
<nav class="mobile-nav" aria-label="Navigation">
  {navItems.map((item) => (
    <a href={item.href} data-section={item.href.slice(1)}>
      <span class="m-num">{item.num}</span>
      <span class="m-lbl">{item.label}</span>
    </a>
  ))}
</nav>

<style>
  header {
    position: fixed;
    top: 20px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 50;
    height: 44px;
    /* デフォルト幅は 200px。モック値 180px だと "YSD-KTN / v3.0.0" + トグルが
       overflow:hidden で切れていた。toggle 側で margin-left は当てず、flex 配置で
       ロゴ直後に並べることで「ロゴと + の間隔」をタイトに保っている。 */
    width: 200px;
    border: 1px solid var(--accent);
    border-radius: 9999px;
    background: var(--bg);
    overflow: hidden;
    display: flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    white-space: nowrap;
    transition: width 0.55s cubic-bezier(0.7, 0, 0.3, 1);
  }

  header .logo {
    font-weight: 700;
    color: var(--accent);
    padding: 0 18px;
    height: 100%;
    display: flex;
    align-items: center;
    flex-shrink: 0;
    border-right: 1px dashed transparent;
    transition: border-color 0.4s;
  }

  header nav {
    max-width: 0;
    opacity: 0;
    overflow: hidden;
    padding: 0;
    display: flex;
    align-items: center;
    height: 100%;
    transition:
      max-width 0.55s cubic-bezier(0.7, 0, 0.3, 1),
      opacity 0.25s ease 0.12s,
      padding 0.5s cubic-bezier(0.7, 0, 0.3, 1),
      border-color 0.4s;
  }

  header nav a {
    padding: 0 14px;
    display: flex;
    gap: 6px;
    border-left: 1px dashed var(--line);
    align-items: center;
    height: 100%;
  }
  header nav a:first-child {
    border-left: 0;
  }
  header nav a:last-child {
    /* "03 CONTACT" は単語が長く、フォント描画の都合で右の dashed 区切り線が
       文字に近接して見えるため、最後の項目だけ padding-right を広めに取る。 */
    padding-right: 22px;
  }
  header nav .num {
    color: var(--dim);
  }

  header .toggle {
    color: var(--accent);
    flex-shrink: 0;
    /* margin-left は当てない。CSS transition は margin: 0 → auto を補間できない
       (auto が数値じゃないため) ので、ホバー時に + が瞬間的に右へ飛んで回転だけ
       遅れて始まるカクつきが起きる。代わりに nav の max-width 展開で
       toggle が自然に右へ押し出される構造にしている。 */
    padding: 0 18px 0 6px;
    font-size: 14px;
    line-height: 1;
    /* 回転中心を + 文字の中心 (要素左端から padding-left 6 + 字幅/2 ≒ 11px) に
       明示。padding 非対称により要素中心 (17px) と文字中心 (11px) がズレているため、
       デフォルトの transform-origin: 50% 50% で回転すると文字の見た目位置が
       斜めに弧を描いてしまう。 */
    transform-origin: 11px center;
    transition: transform 0.4s cubic-bezier(0.7, 0, 0.3, 1);
  }

  /* ===== mobile nav bar (≤720px) ===== */
  .mobile-nav {
    display: none;
  }

  @media (max-width: 720px) {
    /* ピルを非表示 */
    header {
      display: none;
    }

    /* 常時表示ナビバー */
    .mobile-nav {
      display: flex;
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      height: 44px;
      z-index: 50;
      background: var(--bg);
      border-bottom: 1px solid var(--line);
      font-family: var(--font-mono);
      white-space: nowrap;
    }

    .mobile-nav a {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 3px;
      border-right: 1px solid var(--line);
      text-decoration: none;
      color: inherit;
      /* アクティブ時のボトムインジケーター用 */
      box-shadow: inset 0 0 0 var(--accent);
      transition: box-shadow 0.2s, color 0.2s;
      -webkit-tap-highlight-color: transparent;
    }
    .mobile-nav a:last-child {
      border-right: 0;
    }

    .mobile-nav .m-num {
      font-size: 8px;
      letter-spacing: 0.1em;
      color: var(--dim);
      line-height: 1;
      transition: color 0.2s;
    }
    .mobile-nav .m-lbl {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.1em;
      color: var(--fg);
      line-height: 1;
      transition: color 0.2s;
    }

    /* アクティブ状態 */
    .mobile-nav a.is-active {
      box-shadow: inset 0 -2px 0 var(--accent);
    }
    .mobile-nav a.is-active .m-num,
    .mobile-nav a.is-active .m-lbl {
      color: var(--accent);
    }
  }

  /* ===== hover state — pill 展開 ===== */
  header:hover {
    /* 旧 650px から lang 領域 (max-width 100 + padding 0 16px = 132px) を
       削った分を引いて 518 → 520 で詰めたら、CONTACT が overflow:hidden で
       toggle に食われた。実コンテンツ (logo 156 + nav ≈ 371 + toggle 34 ≈ 561)
       に余白 ~20px を載せた 580px が安全圏。 */
    width: 580px;
  }
  header:hover .logo {
    border-right-color: var(--line);
  }
  header:hover nav {
    max-width: 420px;
    opacity: 1;
  }
  header:hover .toggle {
    /* + → × の 45° 回転のみ。右への移動は nav の max-width 展開
       (transition 0.55s cubic-bezier) によって自然に発生する。 */
    transform: rotate(45deg);
  }
</style>

<script>
  // ── モバイルナビ スクロール連動アクティブ表示 ──────────────────
  // IntersectionObserver でセクションの出入りを監視し、
  // viewport 上部に入ったセクションに対応するナビ項目を is-active に切り替える。
  //
  // rootMargin '0px 0px -80% 0px':
  //   viewport の上端〜下から20%の帯でのみ検出。
  //   つまりセクション上端がビューポートの上位20%に入った時点でアクティブ化。

  const mobileLinks = document.querySelectorAll<HTMLAnchorElement>('.mobile-nav a[data-section]');

  function setActive(id: string) {
    mobileLinks.forEach((link) => {
      link.classList.toggle('is-active', link.dataset.section === id);
    });
  }

  // 初期状態: 最上部セクション (index) をアクティブに
  setActive('index');

  const sections = (['index', 'about', 'writing', 'contact'] as const)
    .map((id) => document.getElementById(id))
    .filter((el): el is HTMLElement => el !== null);

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          setActive(entry.target.id);
        }
      });
    },
    { rootMargin: '0px 0px -80% 0px', threshold: 0 },
  );

  sections.forEach((section) => observer.observe(section));
</script>
