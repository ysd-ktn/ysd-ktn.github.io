---
// Hero — 名前 + 役職 + 座標
//
// Phase 5: src/content/profile.json (Content Collections 経由) からデータ読込。
// props は override 用に残してある (将来プレビュー用ページで差し替えたい時用)。
//
// 名前は firstName / lastName で分割。Barlow 800、巨大に表示。
// アクセント色のピリオドは lastName の末尾につける。

import { getEntry } from 'astro:content';

const profile = (await getEntry('profile', 'main'))!.data;

interface Props {
  /** セクションインデックス表記 (例: "00 / INDEX") */
  index?: string;
  /** 緯度 */
  lat?: number;
  /** 経度 */
  lng?: number;
  /** 最終更新 (例: "2026.04.26") */
  lastUpdate?: string;
  /** 名前1行目 */
  firstName?: string;
  /** 名前2行目 */
  lastName?: string;
  /** 役職・状況の1行 */
  role?: string;
}

const {
  index = '00 / INDEX',
  lat = profile.lat,
  lng = profile.lng,
  lastUpdate = profile.lastUpdate,
  firstName = profile.nameFirst,
  lastName = profile.nameLast,
  role = profile.roleHero,
} = Astro.props;
---

<section class="hero" id="index">
  <div class="index">
    [ {index} ] · {lat}°N · {lng}°E · LAST UPDATE {lastUpdate}
  </div>
  <h1>
    {firstName}<br />{lastName}<span class="accent">.</span>
  </h1>
  <div class="role">{role}</div>
</section>

<style>
  /* section の共通枠 (border-top + padding) は global.css 側にあるが、
     hero は最初のセクションなので border-top: 0 が効く。padding は上書き。 */
  .hero {
    padding: 60px 0 100px;
  }

  .hero .index {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--dim);
    margin-bottom: 32px;
    letter-spacing: 0.1em;
  }

  .hero h1 {
    font-family: var(--font-display);
    font-size: clamp(56px, 10vw, 168px);
    font-weight: 800;
    line-height: 0.9;
    letter-spacing: -0.03em;
    margin-bottom: 16px;
  }

  .hero h1 .accent {
    color: var(--accent);
  }

  .hero .role {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--dim);
    display: flex;
    gap: 16px;
    align-items: center;
    margin-top: 24px;
    letter-spacing: 0.05em;
  }

  .hero .role::before {
    content: '>';
    color: var(--accent);
  }

  /* ===== モバイル (~720px) =====
     - h1 の clamp(56px, 10vw, 168px) は 56px に下限ロックで OK (390px 画面なら
       Barlow 800 56px の YOSHIDA / KOTONE は余裕で収まる、 検算済)
     - .index は自然 wrap に任せる (font-size 11px の長文 1行、 単純 word-wrap で OK)
     - .role は flex 単一行で `>` プレフィクス + 1 span 構造のため、 そのままだと
       テキストが 1 行で overflow する。 flex-wrap: wrap + 子要素を block 扱いで
       折り返させ、 font-size も 11px に詰める。 */
  @media (max-width: 720px) {
    .hero {
      padding: 32px 0 64px;
    }
    .hero h1 {
      font-size: clamp(48px, 14vw, 88px);
    }
    .hero .role {
      flex-wrap: wrap;
      gap: 8px;
      font-size: 11px;
      margin-top: 20px;
    }
  }
</style>
