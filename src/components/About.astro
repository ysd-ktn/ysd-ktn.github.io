---
// About — PROFILE (spec シート) + TIMELINE (経歴 + 展覧会)
//
// データは props で受け取る設計。Phase 5 で Content Collections 化したら
// src/content/profile.json と src/content/timeline.json から流し込む想定。
//
// SpecEntry: dl/dt/dd の key/value 1組
// TimelineEntry: 単発イベント (date + tag) と期間付き (from/to + role) の両方に対応

interface SpecEntry {
  key: string;
  value: string;
  /** 値の頭にアクセント色の ● を付与する (STATUS など) */
  accent?: boolean;
}

interface TimelineEntry {
  /** 単発イベント (展覧会等) の日付 */
  date?: string;
  /** 期間: 開始 */
  from?: string;
  /** 期間: 終了 ("PRESENT" を含めるとアクセント色化) */
  to?: string;
  /** バッジ表示 ("EXHIBITION" 等) */
  tag?: string;
  /** タイトル (太字部分) */
  title: string;
  /** 詳細 (単発イベント用、例: "主催 — 大阪") */
  detail?: string;
  /** 役職 (期間エントリ用、例: "UI Designer") */
  role?: string;
}

interface Props {
  /** セクション番号 (例: "01") */
  index?: string;
  /** sec-head の meta 行 */
  meta?: string[];
  /** PROFILE のスペックシート */
  spec?: SpecEntry[];
  /** TIMELINE の行 */
  timeline?: TimelineEntry[];
}

const {
  index = '01',
  meta = ['ABOUT', 'PROFILE + TIMELINE', 'v.2026'],
  spec = [
    { key: 'NAME', value: 'YOSHIDA KOTONE / 吉田琴音' },
    { key: 'ROLE', value: 'UI Designer, occasional illustrator' },
    { key: 'LOCATION', value: '大阪府 / Osaka, Japan (UTC+9)' },
    {
      key: 'FOCUS',
      value:
        'プロダクトUI · デザインシステム · ブランドアイデンティティ · エディトリアル',
    },
    {
      key: 'TOOLS',
      value: 'Figma · After Effects · Cinema 4D · HTML/CSS · Git',
    },
    {
      key: 'WRITING',
      value:
        'デザインシステムやプロセスについて時々書いてます。デザインミートアップで登壇することも。',
    },
    { key: 'STATUS', value: 'OPEN FOR PROJECTS · 2026.Q3', accent: true },
  ],
  timeline = [
    {
      date: '2024.10',
      tag: 'EXHIBITION',
      title: '「TYPE WALK」展',
      detail: '主催 — 大阪',
    },
    { from: '2024.04', to: 'PRESENT', title: '株式会社ACME', role: 'UI Designer' },
    { from: '2021.04', to: '2024.03', title: 'BYLD Inc.', role: 'Junior Designer' },
    {
      from: '2017.04',
      to: '2021.03',
      title: '京都芸術大学',
      role: '美術学部 デザイン学科',
    },
    { from: '2014.04', to: '2017.03', title: '大阪府立XX高等学校' },
  ],
} = Astro.props;
---

<section id="about">
  <div class="sec-head">
    <div class="num">[ {index} ]</div>
    <div class="meta">
      {meta.map((m) => <span>{m}</span>)}
    </div>
  </div>

  <div class="sub-head">[ {index}.1 / PROFILE ]</div>
  <dl class="spec">
    {
      spec.map((entry) => (
        <Fragment>
          <dt>{entry.key}</dt>
          <dd>
            {entry.accent && <span class="status-dot">●</span>}
            {entry.value}
          </dd>
        </Fragment>
      ))
    }
  </dl>

  <div class="sub-head">[ {index}.2 / TIMELINE ]</div>
  <table class="timeline">
    <tbody>
      {
        timeline.map((row) => (
          <tr>
            <td class="date">
              {row.date ? (
                row.date
              ) : (
                <Fragment>
                  {row.from} — {row.to === 'PRESENT' ? <span class="now">PRESENT</span> : row.to}
                </Fragment>
              )}
            </td>
            <td class="title">
              {row.tag && <span class="tag">{row.tag}</span>}
              <strong>{row.title}</strong>
              {row.detail && <Fragment> {row.detail}</Fragment>}
              {row.role && <Fragment> — {row.role}</Fragment>}
            </td>
          </tr>
        ))
      }
    </tbody>
  </table>
</section>

<style>
  /* sub-head: PROFILE / TIMELINE のセクション内見出し */
  .sub-head {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 0.12em;
    margin-bottom: 16px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--accent);
  }
  /* spec シートの直後に来る sub-head は上に余白を取る (PROFILE と TIMELINE の間) */
  .spec + .sub-head,
  .timeline + .sub-head {
    margin-top: 56px;
  }

  /* PROFILE — dl/dt/dd の spec シート */
  .spec {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 0;
  }
  .spec dt {
    padding: 14px 0;
    border-bottom: 1px dashed var(--line);
    color: var(--dim);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
  }
  .spec dd {
    padding: 14px 0;
    border-bottom: 1px dashed var(--line);
    font-size: 15px;
  }
  .spec dt::before {
    content: '[';
    color: var(--accent);
    margin-right: 4px;
  }
  .spec dt::after {
    content: ']';
    color: var(--accent);
    margin-left: 4px;
  }
  .spec .status-dot {
    color: var(--accent);
    margin-right: 6px;
  }

  /* TIMELINE — テーブル */
  .timeline {
    width: 100%;
    border-collapse: collapse;
  }
  .timeline tr {
    border-bottom: 1px dashed var(--line);
  }
  .timeline td {
    padding: 14px 0;
    vertical-align: top;
  }
  .timeline .date {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--dim);
    letter-spacing: 0.05em;
    width: 240px;
  }
  .timeline .date::before {
    content: '[';
    color: var(--accent);
    margin-right: 4px;
  }
  .timeline .date::after {
    content: ']';
    color: var(--accent);
    margin-left: 4px;
  }
  .timeline .title {
    font-size: 15px;
  }
  .timeline .title strong {
    font-weight: 600;
  }
  .timeline .now {
    color: var(--accent);
  }
  .timeline .tag {
    display: inline-block;
    background: var(--accent);
    color: var(--bg);
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    padding: 2px 8px;
    margin-right: 12px;
    vertical-align: middle;
  }
</style>
