---
// About — PROFILE (spec シート) + TIMELINE (経歴 + 展覧会)
//
// Phase 5: src/content/profile.json (PROFILE 用) と
// src/content/timeline.json (TIMELINE 用) からデータ読込。
// props は override 用に残してある。
//
// SpecEntry: dl/dt/dd の key/value 1組
// TimelineEntry: 単発イベント (date + tag) と期間付き (from/to + role) の両方に対応

import { getEntry, getCollection } from 'astro:content';

const profile = (await getEntry('profile', 'main'))!.data;

// timeline は order 降順 (大きい数値ほど上=新しい)
const timelineFromCollection = (await getCollection('timeline'))
  .map((e) => e.data)
  .sort((a, b) => b.order - a.order);

interface SpecEntry {
  key: string;
  value: string;
  /**
   * 値の頭にステータスドットを付与する。
   *  - 'open'   → ● in accent (#00f0bd) — 募集中
   *  - 'closed' → ○ in dim (#6b6b6b)   — 募集停止 (連絡窓口は別途)
   *  - undefined → ドットなし (NAME / ROLE 等の通常行)
   */
  dot?: 'open' | 'closed';
}

interface TimelineEntry {
  /** 単発イベント (展覧会等) の日付 */
  date?: string;
  /** 期間: 開始 */
  from?: string;
  /** 期間: 終了 ("PRESENT" を含めるとアクセント色化) */
  to?: string;
  /** バッジ表示 ("EXHIBITION" 等) */
  tag?: string;
  /** タイトル (太字部分) */
  title: string;
  /** 詳細 (単発イベント用、例: "主催 — 大阪") */
  detail?: string;
  /** 役職 (期間エントリ用、例: "UI Designer") */
  role?: string;
  /** 表示順序 (collection 由来。表示自体には不要だが型整合のため許容) */
  order?: number;
}

interface Props {
  /** セクション番号 (例: "01") */
  index?: string;
  /** sec-head の meta 行 */
  meta?: string[];
  /** PROFILE のスペックシート */
  spec?: SpecEntry[];
  /** TIMELINE の行 */
  timeline?: TimelineEntry[];
}

// profile.json から spec シート 7行を組み立てる。
// 並び順は DESIGN_SPEC の PROFILE モックに合わせて固定 (NAME → ROLE → ... → STATUS)。
const specFromProfile: SpecEntry[] = [
  { key: 'NAME', value: `${profile.nameFirst} ${profile.nameLast} / ${profile.nameJp}` },
  { key: 'LOCATION', value: `${profile.locationJp} / ${profile.locationEn} (UTC${profile.utc})` },
  { key: 'FOCUS', value: profile.focus.join(' · ') },
  { key: 'TOOLS', value: profile.tools.join(' · ') },
  { key: 'WRITING', value: profile.writingIntro },
  { key: 'STATUS', value: profile.statusLabel, dot: profile.statusOpen ? 'open' : 'closed' },
];

const {
  index = '01',
  meta = ['ABOUT', 'PROFILE + TIMELINE + EVENTS', 'v.2026'],
  spec = specFromProfile,
  timeline = timelineFromCollection,
} = Astro.props;

// tag なし → キャリア/学歴タイムライン、tag あり → イベント・展覧会セクション
const careerTimeline = timeline.filter((e) => !e.tag);
const eventsTimeline = timeline.filter((e) => e.tag);
---

<section id="about">
  <div class="sec-head">
    <div class="num">[ {index} ]</div>
    <div class="meta">
      {meta.map((m) => <span>{m}</span>)}
    </div>
  </div>

  <div class="sub-head">[ {index}.1 / PROFILE ]</div>
  <dl class="spec">
    {
      spec.map((entry) => (
        <Fragment>
          <dt>{entry.key}</dt>
          <dd>
            {entry.dot && (
              <span class={`status-dot status-dot--${entry.dot}`}>
                {entry.dot === 'open' ? '●' : '○'}
              </span>
            )}
            {entry.value}
          </dd>
        </Fragment>
      ))
    }
  </dl>

  <div class="sub-head">[ {index}.2 / TIMELINE ]</div>
  <table class="timeline">
    <tbody>
      {
        careerTimeline.map((row) => (
          <tr>
            <td class="date">
              {row.date ? (
                row.date
              ) : (
                <Fragment>
                  {row.from} — {row.to === 'PRESENT' ? <span class="now">PRESENT</span> : row.to}
                </Fragment>
              )}
            </td>
            <td class="title">
              <strong>{row.title}</strong>
              {row.detail && <Fragment> {row.detail}</Fragment>}
              {row.role && <Fragment> — {row.role}</Fragment>}
            </td>
          </tr>
        ))
      }
    </tbody>
  </table>

  {eventsTimeline.length > 0 && (
    <Fragment>
      <div class="sub-head">[ {index}.3 / EVENTS ]</div>
      <table class="timeline">
        <tbody>
          {
            eventsTimeline.map((row) => (
              <tr>
                <td class="date">
                  {row.date ? (
                    row.date
                  ) : (
                    <Fragment>
                      {row.from} — {row.to === 'PRESENT' ? <span class="now">PRESENT</span> : row.to}
                    </Fragment>
                  )}
                </td>
                <td class="title">
                  {row.tag && <span class="tag">{row.tag}</span>}
                  <strong>{row.title}</strong>
                  {row.detail && <Fragment> {row.detail}</Fragment>}
                  {row.role && <Fragment> — {row.role}</Fragment>}
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </Fragment>
  )}
</section>

<style>
  /* sub-head: PROFILE / TIMELINE のセクション内見出し */
  .sub-head {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 0.12em;
    margin-bottom: 16px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--accent);
  }
  /* spec シートの直後に来る sub-head は上に余白を取る (PROFILE と TIMELINE の間) */
  .spec + .sub-head,
  .timeline + .sub-head {
    margin-top: 56px;
  }

  /* PROFILE — dl/dt/dd の spec シート */
  .spec {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 0;
  }
  .spec dt {
    padding: 14px 0;
    border-bottom: 1px dashed var(--line);
    color: var(--dim);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
  }
  .spec dd {
    padding: 14px 0;
    border-bottom: 1px dashed var(--line);
    font-size: 15px;
  }
  .spec dt::before {
    content: '[';
    color: var(--accent);
    margin-right: 4px;
  }
  .spec dt::after {
    content: ']';
    color: var(--accent);
    margin-left: 4px;
  }
  .spec .status-dot {
    margin-right: 6px;
  }
  /* 募集中: ● 塗り潰し + アクセント色 */
  .spec .status-dot--open {
    color: var(--accent);
  }
  /* 募集停止: ○ 中抜き + dim 色 (チャンネルは存在するが non-active のニュアンス) */
  .spec .status-dot--closed {
    color: var(--dim);
  }

  /* TIMELINE — テーブル */
  .timeline {
    width: 100%;
    border-collapse: collapse;
  }
  .timeline tr {
    border-bottom: 1px dashed var(--line);
  }
  .timeline td {
    padding: 14px 0;
    vertical-align: top;
  }
  .timeline .date {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--dim);
    letter-spacing: 0.05em;
    width: 240px;
  }
  .timeline .date::before {
    content: '[';
    color: var(--accent);
    margin-right: 4px;
  }
  .timeline .date::after {
    content: ']';
    color: var(--accent);
    margin-left: 4px;
  }
  .timeline .title {
    font-size: 15px;
  }
  .timeline .title strong {
    font-weight: 600;
  }
  .timeline .now {
    color: var(--accent);
  }
  .timeline .tag {
    display: inline-block;
    background: var(--accent);
    color: var(--bg);
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    padding: 2px 8px;
    margin-right: 12px;
    vertical-align: middle;
  }

  /* ===== モバイル (~720px) =====
     PROFILE: dt 200px + dd 1fr の grid だと、 326px 画面で値の領域が
     126px しか取れず読み辛い + 長いトークン (例: "yosida.kotone@gmail.com" 等)
     は grid item の min-width:auto = min-content により親 grid を突き破って
     横スクロール余白を生む。 1カラム縦積みに切替。

     TIMELINE: table 構造のまま td を block 化。 date を 1行目、 title を
     2行目に積む。 width:240px の固定列も解除。 cell border は tr 側で扱う。 */
  @media (max-width: 720px) {
    .spec {
      grid-template-columns: 1fr;
    }
    .spec dt {
      padding: 14px 0 4px;
      border-bottom: 0;
    }
    .spec dd {
      padding: 0 0 14px;
      font-size: 14px;
      border-bottom: 1px dashed var(--line);
      overflow-wrap: anywhere;
    }
    /* table を捨てて block 縦積みに */
    .timeline,
    .timeline tbody,
    .timeline tr,
    .timeline td {
      display: block;
      width: 100%;
    }
    .timeline tr {
      padding: 12px 0;
      border-bottom: 1px dashed var(--line);
    }
    .timeline td {
      padding: 0;
    }
    .timeline .date {
      width: auto;
      margin-bottom: 4px;
    }
    .timeline .title {
      font-size: 14px;
      overflow-wrap: anywhere;
    }
  }
</style>
