---
// 最小レイアウト。次セッションで DESIGN_SPEC のグローバル CSS を移植する。
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'YOSHIDA KOTONE',
  description = 'UI Designer based in Osaka, Japan.',
} = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
